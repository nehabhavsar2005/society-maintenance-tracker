# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (Neon PostgreSQL or any Postgres instance)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/society_tracker?schema=public"

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_REMEMBER=30d

# ---------------------------------------------------------------------------
# Cloudinary (Image Upload)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---------------------------------------------------------------------------
# Email (Nodemailer via SMTP)
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Society Tracker <no-reply@societytracker.com>"

# Optional: Resend (alternative email provider)
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Business Rules
# ---------------------------------------------------------------------------
DEFAULT_OVERDUE_DAYS=7
